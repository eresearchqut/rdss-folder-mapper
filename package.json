{
  "name": "rdss-folder-mapper",
  "version": "1.0.39",
  "description": "A cross-platform command-line interface (CLI) tool that allows you to create local folder mappings to shared network drives effortlessly. Supported on Windows, macOS, and Linux.",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "build:ts": "tsc",
    "build:pkg": "pkg . --targets node18-linux-x64,node18-macos-x64,node18-win-x64 --out-path dist",
    "build": "npm run build:ts && npm run build:pkg",
    "lint": "gts lint",
    "format": "prettier --write .",
    "clean": "gts clean",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile",
    "pretest": "npm run compile",
    "posttest": "npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eresearchqut/rdss-folder-mapper.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/eresearchqut/rdss-folder-mapper/issues"
  },
  "homepage": "https://github.com/eresearchqut/rdss-folder-mapper#readme",
  "dependencies": {
    "@stdlib/string-truncate": "^0.2.3",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lodash": "^4.17.23",
    "open": "^8.4.2",
    "readline-sync": "^1.4.10",
    "signale": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/commander": "^2.12.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.7.5",
    "@types/readline-sync": "^1.4.8",
    "@types/signale": "^1.4.7",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "gts": "^7.0.0",
    "jest": "^30.3.0",
    "pkg": "^5.8.1",
    "prettier": "^3.8.1",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.0"
  }
}
